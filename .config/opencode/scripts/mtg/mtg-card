#!/usr/bin/env python3
"""Look up a card on Scryfall with full details and optional rulings.

Usage: mtg-card <card-name> [--rulings]
Example: mtg-card "Dockside Extortionist" --rulings
"""

import sys
import os
import json
import time
import urllib.request
import urllib.error
import urllib.parse
import argparse

MAX_RETRIES = 3
RETRY_DELAYS = [1, 3, 8]
RATE_LIMIT_FILE = "/tmp/.mtg-card-last-call"
MIN_INTERVAL = 0.12  # 120ms between calls (~8 req/s, well under Scryfall's 10/s)


def _rate_limit():
    """Ensure MIN_INTERVAL seconds between successive mtg-card invocations."""
    try:
        last = os.path.getmtime(RATE_LIMIT_FILE)
        elapsed = time.time() - last
        if elapsed < MIN_INTERVAL:
            time.sleep(MIN_INTERVAL - elapsed)
    except OSError:
        pass
    # Touch the file to record this call's timestamp
    with open(RATE_LIMIT_FILE, "w") as f:
        f.write("")


def _fetch_json(url: str, retries: int = MAX_RETRIES) -> dict | None:
    _rate_limit()
    req = urllib.request.Request(url, headers={
        "User-Agent": "MTGAgent/1.0",
        "Accept": "application/json",
    })
    for attempt in range(retries):
        try:
            with urllib.request.urlopen(req, timeout=15) as resp:
                return json.loads(resp.read().decode())
        except urllib.error.HTTPError as e:
            if e.code == 404:
                return None
            if e.code == 429 and attempt < retries - 1:
                time.sleep(RETRY_DELAYS[min(attempt, len(RETRY_DELAYS) - 1)])
                continue
            raise
    return None


def fetch_card(name: str) -> dict | None:
    encoded = urllib.parse.quote(name)
    url = f"https://api.scryfall.com/cards/named?fuzzy={encoded}"
    return _fetch_json(url)


def fetch_rulings(card_id: str) -> list[dict]:
    url = f"https://api.scryfall.com/cards/{card_id}/rulings"
    try:
        data = _fetch_json(url)
        return data.get("data", []) if data else []
    except Exception:
        return []


def main():
    parser = argparse.ArgumentParser(description="Look up an MTG card")
    parser.add_argument("name", nargs="+", help="Card name")
    parser.add_argument("--rulings", action="store_true", help="Include rulings")
    args = parser.parse_args()

    card_name = " ".join(args.name)
    card = fetch_card(card_name)

    if not card:
        print(json.dumps({"error": f"Card not found: {card_name}"}))
        sys.exit(1)

    # Handle double-faced cards
    if "card_faces" in card:
        faces = []
        for face in card["card_faces"]:
            faces.append({
                "name": face.get("name", ""),
                "mana_cost": face.get("mana_cost", ""),
                "type_line": face.get("type_line", ""),
                "oracle_text": face.get("oracle_text", ""),
                "power": face.get("power"),
                "toughness": face.get("toughness"),
                "loyalty": face.get("loyalty"),
            })
        oracle_text = " // ".join(f.get("oracle_text", "") for f in card["card_faces"])
    else:
        faces = None
        oracle_text = card.get("oracle_text", "")

    result = {
        "name": card.get("name", ""),
        "mana_cost": card.get("mana_cost", ""),
        "cmc": card.get("cmc", 0),
        "type_line": card.get("type_line", ""),
        "oracle_text": oracle_text,
        "color_identity": card.get("color_identity", []),
        "colors": card.get("colors", []),
        "keywords": card.get("keywords", []),
        "power": card.get("power"),
        "toughness": card.get("toughness"),
        "loyalty": card.get("loyalty"),
        "legalities": {
            "commander": card.get("legalities", {}).get("commander", "unknown"),
            "standard": card.get("legalities", {}).get("standard", "unknown"),
            "modern": card.get("legalities", {}).get("modern", "unknown"),
            "legacy": card.get("legalities", {}).get("legacy", "unknown"),
            "vintage": card.get("legalities", {}).get("vintage", "unknown"),
        },
        "edhrec_rank": card.get("edhrec_rank"),
        "prices": card.get("prices", {}),
        "set": card.get("set_name", ""),
        "rarity": card.get("rarity", ""),
        "scryfall_uri": card.get("scryfall_uri", ""),
    }

    if faces:
        result["card_faces"] = faces

    if card.get("all_parts"):
        related = []
        for part in card["all_parts"]:
            related.append({
                "name": part.get("name", ""),
                "type_line": part.get("type_line", ""),
                "component": part.get("component", ""),
            })
        result["related_cards"] = related

    if args.rulings:
        card_id = card.get("id", "")
        rulings = fetch_rulings(card_id)
        result["rulings"] = [
            {
                "date": r.get("published_at", ""),
                "source": r.get("source", ""),
                "comment": r.get("comment", ""),
            }
            for r in rulings
        ]

    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
