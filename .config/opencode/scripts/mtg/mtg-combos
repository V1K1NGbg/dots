#!/usr/bin/env python3
"""Fetch Commander Spellbook combos for a commander and optional card list.

Usage: mtg-combos <commander-name> [--cards card1 card2 ...] [--limit N]
Example: mtg-combos "Krenko, Mob Boss"
Example: mtg-combos "Krenko, Mob Boss" --cards "Skirk Prospector" "Thornbite Staff"
"""

import sys
import json
import time
import urllib.request
import urllib.error
import urllib.parse
import argparse

MAX_RETRIES = 3
RETRY_DELAYS = [1, 3, 8]


def _fetch_json(url: str, retries: int = MAX_RETRIES) -> dict | None:
    req = urllib.request.Request(url, headers={
        "User-Agent": "MTGAgent/1.0",
        "Accept": "application/json",
    })
    for attempt in range(retries):
        try:
            with urllib.request.urlopen(req, timeout=30) as resp:
                return json.loads(resp.read().decode())
        except urllib.error.HTTPError as e:
            if e.code == 429 and attempt < retries - 1:
                time.sleep(RETRY_DELAYS[min(attempt, len(RETRY_DELAYS) - 1)])
                continue
            raise
    return None


def fetch_combos(commander: str, cards: list[str] | None = None, limit: int = 20) -> dict:
    query_parts = [f'card="{commander}"']
    if cards:
        for card in cards:
            query_parts.append(f'card="{card}"')

    q = " ".join(query_parts)
    params = urllib.parse.urlencode({"q": q, "limit": limit})
    url = f"https://backend.commanderspellbook.com/variants/?{params}"

    try:
        data = _fetch_json(url)
        if data is None:
            return {"error": "No response after retries", "url": url}
    except urllib.error.HTTPError as e:
        return {"error": f"Commander Spellbook returned {e.code}", "url": url}
    except Exception as e:
        return {"error": str(e), "url": url}

    combos = []
    for combo in data.get("results", []):
        uses = []
        for use in combo.get("uses", []):
            card = use.get("card", {})
            uses.append({
                "name": card.get("name", "Unknown"),
                "zone": use.get("zoneLocations", []),
            })

        produces = []
        for prod in combo.get("produces", []):
            feature = prod.get("feature", {})
            produces.append(feature.get("name", "Unknown"))

        requires = []
        for req_item in combo.get("requires", []):
            template = req_item.get("template", {})
            if template:
                requires.append({
                    "name": template.get("name", "Unknown"),
                    "scryfall_query": template.get("scryfallQuery", ""),
                })

        combos.append({
            "id": combo.get("id", ""),
            "cards": uses,
            "produces": produces,
            "requires": requires,
            "description": combo.get("description", ""),
            "prerequisites": combo.get("notablePrerequisites", ""),
            "identity": combo.get("identity", ""),
            "bracket_tag": combo.get("bracketTag", ""),
        })

    output = {
        "commander": commander,
        "total_combos": data.get("count", len(combos)),
        "showing": len(combos),
        "combos": combos,
    }

    if cards:
        output["cards_filter"] = cards

    return output


def main():
    parser = argparse.ArgumentParser(description="Fetch combos from Commander Spellbook")
    parser.add_argument("commander", nargs="+", help="Commander name (before --cards)")
    parser.add_argument("--cards", nargs="*", default=None, help="Cards to filter combos by")
    parser.add_argument("--limit", type=int, default=20, help="Max combos to return (default: 20)")
    args = parser.parse_args()

    commander_parts = []
    card_parts = []
    in_cards = False
    limit = 20
    skip_next = False
    for i, arg in enumerate(sys.argv[1:]):
        if skip_next:
            skip_next = False
            continue
        if arg == "--cards":
            in_cards = True
            continue
        if arg == "--limit":
            skip_next = True
            limit = int(sys.argv[i + 2])
            continue
        if in_cards:
            card_parts.append(arg)
        else:
            commander_parts.append(arg)

    commander_name = " ".join(commander_parts) if commander_parts else " ".join(args.commander)
    cards = card_parts if card_parts else args.cards

    result = fetch_combos(commander_name, cards, limit)
    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
