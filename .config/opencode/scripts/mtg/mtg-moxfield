#!/usr/bin/env python3
"""Fetch a Moxfield deck by public ID and list its cards.

The Moxfield search API does not support commander-based filtering reliably.
Use this script to fetch specific decks when you have a deck URL or public ID.
For aggregate commander data, use mtg-edhrec instead.

Usage:
  mtg-moxfield <publicId>              — Fetch a specific deck by public ID
  mtg-moxfield --url <moxfield-url>    — Fetch a deck by Moxfield URL

Example:
  mtg-moxfield HYT9YcG0bEK1UMvmEEXtTA
  mtg-moxfield --url https://www.moxfield.com/decks/HYT9YcG0bEK1UMvmEEXtTA
"""

import sys
import json
import time
import urllib.request
import urllib.error
import argparse
import re


UA = "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

MAX_RETRIES = 3
RETRY_DELAYS = [1, 3, 8]


def fetch_json(url: str) -> dict:
    req = urllib.request.Request(url, headers={
        "User-Agent": UA,
        "Accept": "application/json",
    })
    for attempt in range(MAX_RETRIES):
        try:
            with urllib.request.urlopen(req, timeout=30) as resp:
                return json.loads(resp.read().decode())
        except urllib.error.HTTPError as e:
            if e.code == 429 and attempt < MAX_RETRIES - 1:
                time.sleep(RETRY_DELAYS[min(attempt, len(RETRY_DELAYS) - 1)])
                continue
            raise
    return {}


def extract_public_id(url_or_id: str) -> str:
    match = re.search(r"moxfield\.com/decks/([A-Za-z0-9_-]+)", url_or_id)
    if match:
        return match.group(1)
    return url_or_id


def get_deck(public_id: str) -> dict:
    url = f"https://api2.moxfield.com/v3/decks/all/{public_id}"
    data = fetch_json(url)

    result = {
        "name": data.get("name", ""),
        "format": data.get("format", ""),
        "views": data.get("viewCount", 0),
        "likes": data.get("likeCount", 0),
        "url": f"https://www.moxfield.com/decks/{public_id}",
        "commanders": [],
        "mainboard": [],
        "mainboard_count": 0,
    }

    boards = data.get("boards", {})

    commanders = boards.get("commanders", {}).get("cards", {})
    for _, card_data in commanders.items():
        card = card_data.get("card", {})
        result["commanders"].append({
            "name": card.get("name", ""),
            "type_line": card.get("type_line", ""),
            "mana_cost": card.get("mana_cost", ""),
        })

    mainboard = boards.get("mainboard", {}).get("cards", {})
    for _, card_data in mainboard.items():
        card = card_data.get("card", {})
        qty = card_data.get("quantity", 1)
        name = card.get("name", "")
        if name:
            result["mainboard"].append({
                "name": name,
                "quantity": qty,
                "type_line": card.get("type_line", ""),
                "mana_cost": card.get("mana_cost", ""),
                "cmc": card.get("cmc", 0),
            })

    result["mainboard_count"] = sum(c["quantity"] for c in result["mainboard"])

    type_breakdown: dict[str, int] = {}
    for card in result["mainboard"]:
        tl = card["type_line"].split(" — ")[0].split(" // ")[0].strip()
        primary = tl.split()[-1] if tl else "Unknown"
        for t in ["Creature", "Instant", "Sorcery", "Artifact", "Enchantment", "Planeswalker", "Land", "Battle"]:
            if t in tl:
                primary = t
                break
        type_breakdown[primary] = type_breakdown.get(primary, 0) + card["quantity"]
    result["type_breakdown"] = type_breakdown

    return result


def main():
    parser = argparse.ArgumentParser(
        description="Fetch a Moxfield deck by public ID or URL"
    )
    parser.add_argument("deck_id", nargs="?", help="Moxfield deck public ID")
    parser.add_argument("--url", help="Moxfield deck URL")
    args = parser.parse_args()

    if not args.deck_id and not args.url:
        parser.print_help()
        sys.exit(1)

    source = args.url if args.url else args.deck_id
    public_id = extract_public_id(source)

    try:
        result = get_deck(public_id)
        print(json.dumps(result, indent=2))
    except urllib.error.HTTPError as e:
        print(json.dumps({"error": f"Moxfield returned {e.code}", "public_id": public_id}))
        sys.exit(1)
    except Exception as e:
        print(json.dumps({"error": str(e), "public_id": public_id}))
        sys.exit(1)


if __name__ == "__main__":
    main()
